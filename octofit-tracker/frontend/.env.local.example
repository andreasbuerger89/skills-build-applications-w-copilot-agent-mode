# Copy this file to .env.local and set the Codespaces environment name.
# VITE_CODESPACE_NAME should be defined for preview deployments.
# Example:
# VITE_CODESPACE_NAME=my-codespace
#
# This environment variable is used by src/lib/api.js to build the API URL:
# https://${import.meta.env.VITE_CODESPACE_NAME}-8000.app.github.dev/api/[component]/
